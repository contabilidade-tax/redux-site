// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

datasource db {
  provider = "postgresql"
}
generator client {
  provider = "prisma-client"
  output   = "./generated"
}

model Post {
  id               String         @id
  caption          String
  media_type       String
  media_url        String
  permalink        String
  timestamp        DateTime
  username         String
  instaPostsData   InstaPostsData @relation(fields: [instaPostsDataId], references: [id])
  instaPostsDataId Int
}

model InstaPostsData {
  id           Int      @id @default(1)
  data         Post[]
  generated_at DateTime @default(now())

  @@map("posts")
}

model TokenData {
  id           Int     @id @default(1)
  access_token String
  token_type   String  @default("bearer")
  expires_in   String
  generated_at String
  permissions  String?

  @@map("token")
}

model CurrentUser {
  id           Int    @id @default(1)
  access_token String
  user_id      String

  @@map("current_user")
}
